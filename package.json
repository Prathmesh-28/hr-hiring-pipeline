{
  "name": "hr-hiring-pipeline",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:career": "yarn workspace career-portal dev",
    "dev:dashboard": "yarn workspace hr-dashboard dev",
    "dev:api": "yarn workspace api dev",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:career\" \"yarn dev:dashboard\"",
    "lint": "yarn workspaces foreach run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
